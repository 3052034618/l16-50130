{
  "name": "graphql-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "admin"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=admin\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:admin": "npm run dev --workspace=admin",
    "build": "npm run build --workspace=server && npm run build --workspace=admin",
    "db:generate": "npm run db:generate --workspace=server",
    "db:push": "npm run db:push --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
